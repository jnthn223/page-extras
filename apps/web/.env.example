# Local development defaults.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Firebase web app config. These are public Firebase client config values,
# but they still need to match the Firebase project used by the API.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=pageextras-43525.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pageextras-43525
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-web-app-id

# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
